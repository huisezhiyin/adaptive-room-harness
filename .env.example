DEEPSEEK_API_KEY=
ROOM_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ROOM_ANTHROPIC_MODEL=deepseek-v4-pro

# Optional: Qwen / DashScope through the OpenAI-compatible runtime.
DASHSCOPE_API_KEY=
# QWEN_API_KEY=  # Alternative name; detected automatically when DASHSCOPE_API_KEY is unset.
ROOM_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ROOM_OPENAI_MODEL=qwen-plus
# ROOM_OPENAI_API_KEY_ENV=DASHSCOPE_API_KEY

# Optional: cap non-blocking advisor calls so slow cheap advisors do not drag automatic wakes.
# Use 120 for quick-deliberation; 45 is usually enough for quick-advisors fan-out.
ROOM_ADVISOR_TIMEOUT_SECONDS=120

# Optional: make the direct Anthropic-compatible runtime read a different key env.
# ROOM_ANTHROPIC_API_KEY_ENV=ANTHROPIC_AUTH_TOKEN

# Optional: route Claude Code CLI through DeepSeek's Anthropic-compatible API.
# ROOM_CLAUDE_PROVIDER=deepseek
# ROOM_CLAUDE_API_KEY_ENV=DEEPSEEK_API_KEY
# ROOM_CLAUDE_DEEPSEEK_MODEL=deepseek-v4-flash
# ROOM_CLAUDE_MODEL=sonnet
# ROOM_CLAUDE_BARE=false
